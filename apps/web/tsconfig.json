{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "noEmit": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@ai/db": [
        "../../packages/db/src/index.ts"
      ],
      "@ai/auth": [
        "../../packages/auth/src/index.ts"
      ],
      "@ai/integrations": [
        "../../packages/integrations/src/index.ts"
      ],
      "@ai/realtime": [
        "../../packages/realtime/src/index.ts"
      ],
      "@ai/shared": [
        "../../packages/shared/src/index.ts"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
