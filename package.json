{
  "name": "ai-site-al-ru",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "start": "npm run start -w apps/web",
    "lint": "npm run lint -w apps/web",
    "typecheck": "npm run typecheck -w apps/web",
    "db:generate": "npm run db:generate -w packages/db",
    "db:migrate": "npm run db:migrate -w packages/db",
    "db:seed": "npm run db:seed -w packages/db"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "effect": "^3.21.1",
    "fast-check": "^4.7.0"
  }
}
